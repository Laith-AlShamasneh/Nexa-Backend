<?xml version="1.0" encoding="utf-8"?>
<!--
  Only needed when running under IIS or IIS Express (the "IIS Express" launch
  profile in launchSettings.json). IIS enforces its own request-size ceiling
  (requestFiltering/requestLimits, default maxAllowedContentLength ~28.6 MB)
  completely independently of Kestrel's MaxRequestBodySize and
  FormOptions.MultipartBodyLengthLimit configured in Program.cs — a request
  that layer rejects never reaches the ASP.NET Core app at all, which is why
  it surfaces as IIS's own "413.1 Request Entity Too Large" HTML page rather
  than anything this app's GlobalExceptionHandler could touch.

  maxAllowedContentLength is a uint; there's no literal "unlimited" setting,
  so this uses the largest value IIS accepts (2^32 - 1 bytes, ~4 GB).

  The <aspNetCore> element below is boilerplate the .NET SDK normally
  generates automatically at build/publish time when no web.config exists;
  it's included explicitly here so the SDK updates it in place (process path,
  arguments, hosting model) instead of skipping generation because a
  web.config is already present.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\WebApi.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="4294967295" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
