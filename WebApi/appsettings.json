{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "SqlConnection": "Server=localhost\\SQLEXPRESS;Database=MyMoney;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "Jwt": {
    "Issuer": "Nexa",
    "Audience": "Nexa.Client",
    "SecretKey": "",
    "ExpiryMinutes": 15
  },

  "Authentication": {
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 30,
    "EmailConfirmationExpiryHours": 24,
