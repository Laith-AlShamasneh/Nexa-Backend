{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "SqlConnection": "Server=localhost\\SQLEXPRESS;Database=Nexa;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "Jwt": {
    "Issuer": "Nexa",
    "Audience": "Nexa.Client",
    "SecretKey": "",
    "ExpiryMinutes": 15
  },

  "Authentication": {
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 30,
    "EmailConfirmationExpiryHours": 24,
    "ConfirmEmailBaseUrl": "https://app.nexa.local/confirm-email",
    "PasswordResetExpiryMinutes": 15,
    "ResetPasswordBaseUrl": "",
    "AcceptInvitationBaseUrl": "",
    "ValidateAccessTokenStamp": false
  },

  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "UseSsl": true,
    "FromAddress": "",
    "FromName": "Nexa"
  },

  "Storage": {
    "FolderPaths": {
      "ProfilePictures": "profile-pictures",
      "OrganizationLogos": "organization-logos"
    },
    "CopyBufferSizeBytes": 1048576
  },

  "BackgroundJobs": {
    "PollingIntervalSeconds": 10,
    "BatchSize": 20,
    "MaxDegreeOfParallelism": 4,
    "JobTimeoutSeconds": 300,
    "RunSchedulers": true
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.MSSqlServer"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Server=localhost\\SQLEXPRESS;Database=NexaLogs;Trusted_Connection=True;TrustServerCertificate=True",
          "sinkOptionsSection": {
            "tableName": "ApplicationLogs",
            "autoCreateSqlTable": true
          },
          "columnOptionsSection": {
            "customColumns": [
              {
                "ColumnName": "CorrelationId",
                "DataType": "nvarchar",
                "DataLength": 50,
                "AllowNull": true
              },
              {
                "ColumnName": "UserId",
                "DataType": "bigint",
                "AllowNull": true
              },
              {
                "ColumnName": "OrganizationId",
                "DataType": "nvarchar",
                "DataLength": 50,
                "AllowNull": true
              },
              {
                "ColumnName": "IPAddress",
                "DataType": "nvarchar",
                "DataLength": 50,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestPath",
                "DataType": "nvarchar",
                "DataLength": 2048,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestMethod",
                "DataType": "nvarchar",
                "DataLength": 10,
                "AllowNull": true
              },
              {
                "ColumnName": "RequestBody",
                "DataType": "nvarchar",
                "DataLength": -1,
                "AllowNull": true
              }
            ]
          }
        }
      }
    ]
  }
}
